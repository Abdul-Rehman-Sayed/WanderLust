<% layout("/layouts/boilerplate.ejs") %>
<script>
  const mapToken = "<%= process.env.MAP_TOKEN %>";
  const listing = <%- JSON.stringify(listing) %>;
</script>

<div class="container mt-3">
  <div class="row mb-2">
    <div class="col-lg-8 offset-lg-2 col-md-10 offset-md-1 col-12">
      <a href="/listings" class="btn btn-sm btn-outline-dark rounded-pill ps-3 pe-3 mb-2"><i class="fa-solid fa-arrow-left me-1"></i> Back</a>
    </div>
  </div>
  <div class="row">
    <div class="col-lg-8 offset-lg-2 col-md-10 offset-md-1 col-12">
      <h2><b><%= listing.title %></b></h2>
    </div>

    <div class="card col-lg-8 offset-lg-2 col-md-10 offset-md-1 col-12 show-card listing-card">
      <img
        src="<%= listing.image.url %>"
        class="card-img-top show-img"
        alt="listing_image"
      />
      <div class="card-body mt-2">
        <p class="card-text">Owned by <i><%= listing.owner.username %></i></p>
        <p class="card-text"><%= listing.description %></p>
        <p class="card-text"><%= listing.location %></p>
        <p class="card-text"><%= listing.country %></p>
        <% if(listing.category) { %>
          <span class="badge bg-secondary"><%= listing.category %></span>
        <% } %>
      </div>
    </div>
  </div>

  <% if(currentUser && listing.owner._id.equals(currentUser._id)) { %>
  <div class="row mt-3">
    <div class="col-lg-8 offset-lg-2 col-md-10 offset-md-1 col-12 d-flex gap-2">
      <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark edit-btn"
        >Edit</a
      >
      <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
        <button class="btn btn-dark del-btn">Delete</button>
      </form>
    </div>
  </div>
  <% } %>

  <div class="row mt-4">
    <div class="col-lg-8 offset-lg-2 col-md-10 offset-md-1 col-12">
      <% if(currentUser) { %>
      <hr />
      <h4>Leave a Review</h4>
      <form
        action="/listings/<%= listing._id %>/reviews"
        method="POST"
        class="mb-3 needs-validation"
        novalidate
      >
        <div class="mb-3 mt-3">
          <label for="rating" class="form-label">Rating</label>
          <fieldset class="starability-slot">
            <input
              type="radio"
              id="no-rate"
              class="input-no-rate"
              name="review[rating]"
              value="1"
              checked
              aria-label="No rating."
            />
            <input
              type="radio"
              id="first-rate1"
              name="review[rating]"
              value="1"
            />
            <label for="first-rate1" title="Terrible">1 star</label>
            <input
              type="radio"
              id="first-rate2"
              name="review[rating]"
              value="2"
            />
            <label for="first-rate2" title="Not good">2 stars</label>
            <input
              type="radio"
              id="first-rate3"
              name="review[rating]"
              value="3"
            />
            <label for="first-rate3" title="Average">3 stars</label>
            <input
              type="radio"
              id="first-rate4"
              name="review[rating]"
              value="4"
            />
            <label for="first-rate4" title="Very good">4 stars</label>
            <input
              type="radio"
              id="first-rate5"
              name="review[rating]"
              value="5"
            />
            <label for="first-rate5" title="Amazing">5 stars</label>
          </fieldset>
        </div>

        <div class="mb-3 mt-3">
          <label for="comment" class="form-label">Comments</label>
          <textarea
            name="review[comment]"
            id="comment"
            class="form-control"
            cols="30"
            rows="5"
            required
          ></textarea>
          <div class="invalid-feedback">
            Please add some comments for reviews
          </div>
        </div>
        <button class="btn btn-outline-dark mt-4 mb-4">Submit</button>
      </form>
      <% } %>
      <hr />

      <% if(listing.reviews.length > 0) { %>
      <div class="row">
        <h4 class="mb-4 mt-2"><b>All Reviews</b></h4>
        <% for (review of listing.reviews) { %>

        <div class="col-md-6 mb-3">
          <div class="card p-3">
            <div class="card-body">
              <h5 class="card-title">@<%= review.author.username %></h5>
              <p
                class="starability-result card-text"
                data-rating="<%= review.rating %>"
              ></p>
              <p class="card-text"><%= review.comment %></p>
              <% if(currentUser && review.author._id.equals(currentUser._id)) {
              %>
              <form
                method="POST"
                action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
              >
                <button class="btn btn-sm btn-dark del-btn">
                  Delete Review
                </button>
              </form>
              <% } %>
            </div>
          </div>
        </div>
        <% } %>
      </div>
      <% } %>
    </div>
  </div>

  <div class="row mt-3 mb-3">
    <div class="col-lg-8 offset-lg-2 col-md-10 offset-md-1 col-12">
      <h3>Where you'll be</h3>
      <div id="map"></div>
    </div>
  </div>
</div>

<script src="/js/map.js"></script>
